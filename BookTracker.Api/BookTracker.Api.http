@BookTracker.Api_HostAddress = http://localhost:5202

### Get Books Page 1
GET {{BookTracker.Api_HostAddress}}/books?page=1&pageSize=10

### Get Books Page 2
GET {{BookTracker.Api_HostAddress}}/books?page=2&pageSize=10

### Search Books
GET {{BookTracker.Api_HostAddress}}/books?search=octopus

### Get Book by Id
GET {{BookTracker.Api_HostAddress}}/books/1

### Get Book by Id (not found)
GET {{BookTracker.Api_HostAddress}}/books/9999

### Create Book
POST {{BookTracker.Api_HostAddress}}/books
Content-Type: application/json

{
  "title": "Dune",
  "author": "Frank Herbert",
  "year": 1965
}

### Update Book
PUT {{BookTracker.Api_HostAddress}}/books/1
Content-Type: application/json

{
  "title": "Changes",
  "author": "David Bowie",
  "year": 1971
}

### Update Book (not found)
PUT {{BookTracker.Api_HostAddress}}/books/9999
Content-Type: application/json

{
  "title": "Unknown Book",
  "author": "Unknown Author",
  "year": 2000
}

### Delete Book
DELETE {{BookTracker.Api_HostAddress}}/books/1

### Delete Book (not found)
DELETE {{BookTracker.Api_HostAddress}}/books/9999

### Get Members
GET {{BookTracker.Api_HostAddress}}/members

### Get Member by Id
GET {{BookTracker.Api_HostAddress}}/members/1

### Create Member
POST {{BookTracker.Api_HostAddress}}/members
Content-Type: application/json

{
  "name": "Ada Lovelace",
  "email": "ada@example.com"
}

### Update Member
PUT {{BookTracker.Api_HostAddress}}/members/1
Content-Type: application/json

{
  "name": "Ada Byron",
  "email": "ada.byron@example.com"
}

### Delete Member
DELETE {{BookTracker.Api_HostAddress}}/members/1